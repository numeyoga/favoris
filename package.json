{
  "name": "favoris",
  "version": "1.0.0",
  "description": "Gestionnaire de favoris multi-espaces, offline-first, avec synchronisation optionnelle par espace.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
